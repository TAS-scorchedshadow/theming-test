{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "core",
  "projectType": "library",
  "sourceRoot": "packages/core",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "packages/core"
      },
      "inputs": [
        "{projectRoot}/tokens/**/*.json",
        "{projectRoot}/adapters/**/*.js"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ]
    }
  }
}
