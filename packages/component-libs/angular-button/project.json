{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "angular-button",
  "projectType": "library",
  "sourceRoot": "packages/component-libs/angular-button/src",
  "implicitDependencies": ["design-tokens"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "packages/component-libs/angular-button"
      },
      "inputs": [
        "{projectRoot}/src/styles/_component-tokens.scss"
      ],
      "outputs": [
        "{projectRoot}/dist/component-tokens.css"
      ]
    }
  }
}
