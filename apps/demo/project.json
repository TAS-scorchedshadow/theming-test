{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "demo",
  "projectType": "application",
  "sourceRoot": "apps/demo/src",
  "implicitDependencies": ["design-tokens", "angular-button", "bootstrap-lib"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "ng build demo" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "ng serve demo" }
    }
  }
}
